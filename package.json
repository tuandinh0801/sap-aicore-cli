{
  "name": "sap-ai-core-cli",
  "version": "0.0.2",
  "description": "CLI helper for SAP AI Core - manage prompt templates, scenarios, and AI resources",
  "type": "module",
  "bin": {
    "saic-cli": "./bin/index.js"
  },
  "files": [
    "bin",
    "lib",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build": "node build.mjs && node postbuild.mjs && tsc --emitDeclarationOnly",
    "clean": "rm -rf lib",
    "prebuild": "npm run clean",
    "start": "node lib/cli.js",
    "dev": "tsx src/cli.ts",
    "install-global": "npm run build && npm link",
    "uninstall-global": "npm unlink -g sap-ai-core-cli"
  },
  "keywords": [
    "sap",
    "ai core",
    "prompt registry",
    "cli"
  ],
  "license": "ISC",
  "dependencies": {
    "@sap-ai-sdk/prompt-registry": "^2.8.0",
    "@sap/cds": "^9.0.0",
    "@types/yargs": "^17.0.35",
    "chalk": "^5.6.2",
    "yaml": "^2.8.2",
    "yargs": "^18.0.0"
  },
  "devDependencies": {
    "@cap-js/cds-types": "^0.15.0",
    "@types/node": "^22.19.15",
    "esbuild": "^0.27.4",
    "glob": "^13.0.6",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  },
  "cds": {
    "requires": {
      "aicore": {
        "kind": "rest",
        "vcap": {
          "label": "aicore"
        }
      }
    }
  }
}
